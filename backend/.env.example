# =============================================
# GROWLYTICS BACKEND — ENVIRONMENT VARIABLES
# Copy this to .env and fill in your values
# NEVER commit .env to version control
# =============================================

# Server
PORT=5000
NODE_ENV=development

# PostgreSQL (Supabase or any Postgres)
DATABASE_URL=postgresql://user:password@host:5432/growlytics

# JWT — use a long random string (min 64 chars)
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_STRING
JWT_EXPIRES_IN=7d

# OpenAI
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_KEY
OPENAI_MODEL=gpt-3.5-turbo

# CORS — your frontend URL
FRONTEND_URL=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
